# Audio processing
TARGET_SR=16000

# --- Model / component sources (Artifactory) ---------------------------------
# ASR model source. One of:
#   * a repo id (default)                    -> from_pretrained
#   * a local .nemo path                     -> restore_from
#   * an http(s) URL to a .nemo (Artifactory generic repo) -> download + restore
MODEL_SOURCE=nvidia/parakeet-tdt-0.6b-v2
# Directory downloaded .nemo artifacts are cached in
MODEL_CACHE_DIR=/opt/models/asr
# Optional Hugging Face endpoint override (e.g. an Artifactory HF remote proxy),
# used when MODEL_SOURCE is a repo id:
#   HF_ENDPOINT=https://artifactory.example.com/artifactory/api/huggingfaceml/hf-remote
HF_ENDPOINT=
# Silero VAD source: torch.hub repo id (github) or a vendored local dir (local)
VAD_SOURCE=snakers4/silero-vad
VAD_SOURCE_TYPE=github
# Build-time only (docker compose build args): package/wheel indexes
# PIP_INDEX_URL=https://artifactory.example.com/artifactory/api/pypi/pypi-remote/simple
# PIP_EXTRA_INDEX_URL=
# TORCH_INDEX_URL=https://artifactory.example.com/artifactory/api/pypi/pytorch-remote/simple

# Performance settings
MODEL_PRECISION=fp16
DEVICE=cuda
BATCH_SIZE=16
BATCH_WINDOW_MS=100

# Security / DoS limits
# API_KEY: leave unset/empty to run open (no auth). Set it to require every
# REST request and WebSocket connection to present the matching key via
# `x-api-key: <key>` or `Authorization: Bearer <key>`.
API_KEY=
# Header name clients use to send the key (default: x-api-key)
API_KEY_HEADER=x-api-key
# Reject uploads larger than this many bytes (default 100 MiB)
MAX_UPLOAD_BYTES=104857600
# Reject audio longer than this many seconds (hard ceiling on decoded audio)
MAX_AUDIO_DURATION=3600
# Timeout (seconds) for the ffmpeg transcode step
PROCESSING_TIMEOUT=60
VAD_THRESHOLD=0.5

# Logging
LOG_LEVEL=INFO
